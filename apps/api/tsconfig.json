{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  },
  "references": [
    {
      "path": "../../packages/shared"
    },
    {
      "path": "../../packages/adapters"
    },
    {
      "path": "../../packages/db"
    }
  ],
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", ".wrangler"]
}
